<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="mx.uv.fei.presentation.controllers.RegisterExitController"
      prefHeight="500.0" prefWidth="700.0" style="-fx-background-color: #f8f9fa;">
    
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="Registrar Salida" textFill="#e74c3c">
        <font>
            <Font name="System Bold" size="28.0" />
        </font>
    </Label>
    
    <Label text="Ingrese el identificador del visitante que se retira:" textFill="#7f8c8d">
        <font>
            <Font size="16.0" />
        </font>
        <VBox.margin>
            <Insets bottom="10.0" />
        </VBox.margin>
    </Label>

    <TextField fx:id="identifierTextField" promptText="Matrícula, Número de Personal o Folio" 
               prefWidth="400.0" maxWidth="400.0" prefHeight="45.0" 
               style="-fx-font-size: 16px; -fx-background-radius: 5;" />

    <Button text="Registrar Salida" onAction="#onRegisterExitClick" 
            prefWidth="200.0" prefHeight="45.0" 
            style="-fx-font-size: 16px; -fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" />

    <Button text="Volver al Menú" onAction="#onBackClick" 
            prefWidth="200.0" prefHeight="40.0" 
            style="-fx-font-size: 14px; -fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-cursor: hand;" />

</VBox>