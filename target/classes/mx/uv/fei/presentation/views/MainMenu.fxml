<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="25.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="mx.uv.fei.presentation.controllers.MainMenuController"
      prefHeight="500.0" prefWidth="700.0" style="-fx-background-color: #f8f9fa;">
    
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label text="Sistema de Control de Accesos" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="32.0" />
        </font>
    </Label>
    
    <Label text="Bienvenido, seleccione una acción:" textFill="#7f8c8d">
        <font>
            <Font size="18.0" />
        </font>
    </Label>

    <Button fx:id="registerEntranceButton" text="Registrar Entrada" 
            onAction="#onRegisterEntranceClick" prefWidth="280.0" prefHeight="50.0" 
            style="-fx-font-size: 16px; -fx-background-radius: 8; -fx-cursor: hand;" />
            
    <Button fx:id="registerExitButton" text="Registrar Salida" 
            onAction="#onRegisterExitClick" prefWidth="280.0" prefHeight="50.0" 
            style="-fx-font-size: 16px; -fx-background-radius: 8; -fx-cursor: hand;" />
            
    <Button fx:id="viewHistoryButton" text="Historial de Visitas" 
            onAction="#onViewHistoryClick" prefWidth="280.0" prefHeight="50.0" 
            style="-fx-font-size: 16px; -fx-background-radius: 8; -fx-cursor: hand;" />

</VBox>